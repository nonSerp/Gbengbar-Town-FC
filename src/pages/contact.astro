---
// src/pages/contact.astro
import ContactForm from '../components/ContactForm';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Get in touch with Gbengbar Town FC" />
    <title>Contact Us — Gbengbar Town FC</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      /* ══════════════════════════════
         DESIGN TOKENS
      ══════════════════════════════ */
      :root {
        --green:  #1a4d2e;
        --gold:   #f4b53f;
        --dark:   #0a1f14;
        --light:  #f5f5f5;
        --glass:  rgba(255,255,255,.04);
        --border: rgba(26,77,46,.55);

        --ff-display: "Bebas Neue", sans-serif;
        --ff-body:    "Outfit", sans-serif;

        /* fluid spacing */
        --px: clamp(1.25rem, 6vw, 5rem);
        --pt: clamp(1.5rem, 4vw, 3.5rem);
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

      body {
        font-family: var(--ff-body);
        background: var(--dark);
        color: var(--light);
        min-height: 100dvh;
        overflow-x: hidden;
      }

      /* ── atmospheric mesh ── */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background:
          radial-gradient(ellipse 75% 65% at  7% 12%, rgba(26,77,46,.55) 0%, transparent 58%),
          radial-gradient(ellipse 50% 45% at 93% 88%, rgba(244,181,63,.07) 0%, transparent 55%);
        pointer-events: none;
        z-index: 0;
      }

      /* ── grid texture ── */
      body::after {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(rgba(26,77,46,.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(26,77,46,.045) 1px, transparent 1px);
        background-size: 52px 52px;
        pointer-events: none;
        z-index: 0;
      }

      /* ── page shell ── */
      .shell {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
      }

      /* ══════════════════════════════
         TOP NAV / BREADCRUMB
      ══════════════════════════════ */
      .topnav {
        padding: var(--pt) var(--px) 0;
        display: flex;
        align-items: center;
        gap: .85rem;
      }

      .back {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        font-size: .69rem;
        font-weight: 600;
        letter-spacing: .14em;
        text-transform: uppercase;
        color: rgba(245,245,245,.38);
        text-decoration: none;
        transition: color .22s;
      }
      .back:hover { color: var(--gold); }
      .back svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2.3; }

      .breadcrumb-sep   { color: rgba(245,245,245,.16); font-size: .75rem; }
      .breadcrumb-label {
        font-size: .69rem;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: rgba(245,245,245,.26);
      }

      /* ══════════════════════════════
         MAIN — 2-col grid
      ══════════════════════════════ */
      main {
        flex: 1;
        display: grid;
        grid-template-columns: 1fr 1px 1fr;
        max-width: 1380px;
        margin: 0 auto;
        width: 100%;
        padding:
          clamp(2.5rem, 5.5vw, 5rem)
          var(--px)
          clamp(3rem, 7vw, 6rem);
      }

      /* ══════════════════════════════
         LEFT PANEL — info
      ══════════════════════════════ */
      .info-panel {
        padding-right: clamp(2rem, 5vw, 5.5rem);
        position: sticky;
        top: 3rem;
        align-self: start;
        animation: slideL .65s cubic-bezier(.22,1,.36,1) both;
      }

      @keyframes slideL {
        from { opacity: 0; transform: translateX(-20px); }
        to   { opacity: 1; transform: translateX(0); }
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        font-size: .66rem;
        font-weight: 700;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 1.4rem;
      }
      .eyebrow-bar {
        display: block;
        width: 24px; height: 2px;
        background: var(--gold);
        border-radius: 2px;
        flex-shrink: 0;
      }

      /* giant heading */
      h1 {
        font-family: var(--ff-display);
        font-size: clamp(3.8rem, 8.5vw, 9rem);
        line-height: .87;
        letter-spacing: .01em;
        text-transform: uppercase;
        margin-bottom: 1.8rem;
      }
      h1 .accent { color: var(--gold); display: block; }

      .intro {
        font-size: clamp(.88rem, 1.25vw, 1.05rem);
        font-weight: 300;
        line-height: 1.8;
        color: rgba(245,245,245,.56);
        max-width: 34ch;
        margin-bottom: 2.8rem;
      }

      /* ── info cards ── */
      .info-cards { display: flex; flex-direction: column; gap: .85rem; }

      .ic {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: .95rem 1.25rem;
        background: var(--glass);
        border: 1px solid var(--border);
        border-radius: 10px;
        text-decoration: none;
        color: inherit;
        transition: border-color .28s, background .28s, transform .28s;
        cursor: pointer;
      }
      .ic:hover {
        border-color: var(--gold);
        background: rgba(244,181,63,.06);
        transform: translateX(6px);
      }

      .ic-icon {
        width: 40px; height: 40px; min-width: 40px;
        background: var(--green);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
      }
      .ic-icon svg { width: 17px; height: 17px; stroke: var(--gold); fill: none; stroke-width: 1.8; }

      .ic-label {
        display: block;
        font-size: .63rem; font-weight: 700;
        letter-spacing: .14em; text-transform: uppercase;
        color: rgba(245,245,245,.32);
        margin-bottom: 2px;
      }
      .ic-value { font-size: .9rem; font-weight: 500; }

      /* ══════════════════════════════
         VERTICAL DIVIDER
      ══════════════════════════════ */
      .vline {
        background: linear-gradient(
          to bottom,
          transparent     0%,
          rgba(26,77,46,.85) 18%,
          rgba(244,181,63,.2) 50%,
          rgba(26,77,46,.85) 82%,
          transparent    100%
        );
        align-self: stretch;
      }

      /* ══════════════════════════════
         RIGHT PANEL — form host
      ══════════════════════════════ */
      .form-panel {
        padding-left: clamp(2rem, 5vw, 5.5rem);
        animation: slideR .65s .1s cubic-bezier(.22,1,.36,1) both;
      }

      @keyframes slideR {
        from { opacity: 0; transform: translateX(20px); }
        to   { opacity: 1; transform: translateX(0); }
      }

      .form-heading { margin-bottom: 2.2rem; }
      .form-heading h2 {
        font-family: var(--ff-display);
        font-size: clamp(1.7rem, 3vw, 2.8rem);
        letter-spacing: .05em;
        text-transform: uppercase;
        margin-bottom: .38rem;
      }
      .form-heading p {
        font-size: .8rem;
        color: rgba(245,245,245,.32);
        line-height: 1.5;
      }
      .form-heading p a {
        color: var(--gold);
        text-decoration: none;
        font-weight: 600;
      }
      .form-heading p a:hover { text-decoration: underline; }

      /* ══════════════════════════════
         RESPONSIVE
      ══════════════════════════════ */

      /* Tablet ≤ 900 px */
      @media (max-width: 900px) {
        main {
          grid-template-columns: 1fr;
          gap: 3rem;
          padding-top: 2rem;
        }

        .vline { display: none; }

        .info-panel { padding-right: 0; position: static; }
        h1 { font-size: clamp(3.5rem, 14vw, 6rem); }
        .intro { max-width: 100%; }

        .info-cards { flex-direction: row; flex-wrap: wrap; }
        .ic { flex: 1 1 calc(50% - .43rem); min-width: 200px; }

        .form-panel { padding-left: 0; }
      }

      /* Mobile ≤ 600 px */
      @media (max-width: 600px) {
        main { padding: 1.5rem var(--px) 3rem; gap: 2.5rem; }
        h1 { font-size: clamp(3rem, 18vw, 4.5rem); }
        .ic { flex: 1 1 100%; }
      }

      /* XS ≤ 380 px */
      @media (max-width: 380px) {
        h1 { font-size: 2.9rem; }
      }
    </style>
  </head>

  <body>
    <Header/>

     

      <main>

        <!-- ── LEFT: info ── -->
        <section class="info-panel" aria-label="Contact information">

          <span class="eyebrow">
            <span class="eyebrow-bar" aria-hidden="true"></span>
            Reach out
          </span>

          <h1>Contact<span class="accent">Us</span></h1>

          <p class="intro">
            Questions, partnerships, or just want to say hello?
            Our team responds within <strong style="color:var(--gold);font-weight:600;">24 hours</strong> — no message goes unread.
          </p>

          <div class="info-cards">

            <a class="ic" href="mailto:info@mightyeagle.com">
              <div class="ic-icon">
                <svg viewBox="0 0 24 24">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <polyline points="2,4 12,13 22,4"/>
                </svg>
              </div>
              <div>
                <span class="ic-label">Email</span>
                <span class="ic-value">gtmefc@gmail.com</span>
              </div>
            </a>

            <a class="ic" href="tel:+231770536706">
              <div class="ic-icon">
                <svg viewBox="0 0 24 24">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.33 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.05 12.05 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.92a2 2 0 0 1 2.11-.45 12.05 12.05 0 0 0 2.81.7A2 2 0 0 1 21.73 16.92z"/>
                </svg>
              </div>
              <div>
                <span class="ic-label">Phone</span>
                <span class="ic-value">+231 770 536706</span>
              </div>
            </a>

            <div class="ic">
              <div class="ic-icon">
                <svg viewBox="0 0 24 24">
                  <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <span class="ic-label">Location</span>
                <span class="ic-value">Paynesville, Liberia</span>
              </div>
            </div>

            <div class="ic">
              <div class="ic-icon">
                <svg viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <span class="ic-label">Office Hours</span>
                <span class="ic-value">Mon – Sat, 9 am – 5 pm</span>
              </div>
            </div>

          </div>
        </section>

        <!-- vertical rule -->
        <div class="vline" aria-hidden="true"></div>

        <!-- ── RIGHT: form ── -->
        <section class="form-panel" aria-label="Send a message">

          <div class="form-heading">
            <h2>Send a Message</h2>
            <p>
              Fields marked <span style="color:var(--gold);font-weight:700;">*</span> are required.
              <code style="color:var(--gold);"></code> 
              <a href="https://formspree.io" target="_blank" rel="noopener"></a>.
            </p>
          </div>

          <!-- React island — hydrates on client -->
          <ContactForm client:load />

        </section>

      </main>
    </div>
    <Footer/>
  </body>
</html>